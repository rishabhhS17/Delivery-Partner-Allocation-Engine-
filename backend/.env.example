PORT=5000
MONGODB_URI=your_mongodb_atlas_connection_string
JWT_SECRET=your_jwt_secret_key
ADMIN_PASSWORD=your_admin_password
MAPBOX_TOKEN=your_mapbox_secret_token
SESSION_SECRET=your_session_secret
FRONTEND_URL=https://your-app.vercel.app
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-backend.onrender.com/api/auth/google/callback

# Optional — powers registration/forgot-password OTP emails. When unset, OTPs are logged to the
# server console instead, so those flows stay testable without real mail credentials.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@your-app.com
